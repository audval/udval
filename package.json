{
  "name": "next-js-boilerplate",
  "version": "3.67.2",
  "author": "Ixartz (https://github.com/ixartz)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:spotlight": "spotlight-sidecar",
    "dev:next": "next dev --turbopack",
    "dev": "run-p dev:*",
    "build": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit --pretty",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "commit": "cz",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c production -- drizzle-kit migrate",
    "db:studio": "dotenv -c production -- drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:serve": "http-server storybook-static --port 6006 --silent",
    "serve-storybook": "run-s storybook:*",
    "test-storybook:ci": "start-server-and-test serve-storybook http://127.0.0.1:6006 test-storybook",
    "prepare": "husky"
  },
  "dependencies": {
    "@arcjet/next": "^1.1.0",
    "@clerk/localizations": "^3.37.2",
    "@clerk/nextjs": "^6.39.0",
    "@electric-sql/pglite": "^0.3.15",
    "@hookform/resolvers": "^5.2.2",
    "@logtail/pino": "^0.5.7",
    "@sentry/nextjs": "^9.47.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "drizzle-orm": "^0.45.1",
    "next": "^15.5.12",
    "next-intl": "^4.8.3",
    "pg": "^8.19.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "posthog-js": "^1.356.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@faker-js/faker": "^9.9.0",
    "@next/bundle-analyzer": "^15.5.12",
    "@next/eslint-plugin-next": "^15.3.1",
    "@percy/cli": "1.31.8",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@spotlightjs/spotlight": "^2.13.3",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.17",
    "@storybook/addon-onboarding": "^8.6.17",
    "@storybook/blocks": "^8.6.12",
    "@storybook/nextjs": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@storybook/test": "^8.6.12",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/expect": "^3.1.3",
    "checkly": "^5.6.0",
    "commitizen": "^4.3.1",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.26.0",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.8.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-testing-library": "^7.16.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^24.2.9",
    "start-server-and-test": "^2.1.5",
    "storybook": "^8.6.12",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.3",
    "vitest-fail-on-console": "^0.10.1"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}
